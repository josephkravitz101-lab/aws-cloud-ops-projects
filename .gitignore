# OS junk
.DS_Store
Thumbs.db

# VS Code settings
.vscode/

# Python
__pycache__/
*.pyc

# Node (if you ever use it)
node_modules/

# Terraform directories
**/.terraform/*
.terraform.lock.hcl   # Usually commit this one, but sometimes ignore during early learning

# State files - NEVER commit these!
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Variable files (often contain secrets)
*.tfvars
*.tfvars.json
*.auto.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files
*.tfplan

# Local CLI config
.terraformrc
terraform.rc

# AWS credentials (never commit these)
*.pem
*.key
.aws/

# Logs
*.log

# Zip files / build artifacts
*.zip
*.tar
*.gz
dist/
build/
